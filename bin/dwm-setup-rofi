#!/usr/bin/env bash
set -euo pipefail

repo_root="${DWM_REPO_ROOT:-}"
if [[ -z "$repo_root" && -f "$HOME/.config/dwm/repo_root" ]]; then
  repo_root="$(sed -n '1p' "$HOME/.config/dwm/repo_root")"
fi
if [[ -z "$repo_root" ]]; then
  repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
fi

exec env DWM_REPO_ROOT="$repo_root" "$repo_root/scripts/setup-rofi-suite.sh" "$@"
